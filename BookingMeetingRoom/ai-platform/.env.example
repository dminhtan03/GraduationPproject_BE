# =========================
# APP CONFIG
# =========================
APP_NAME=AI Platform
APP_VERSION=0.1.0
DEBUG=false

# =========================
# SERVER
# =========================
HOST=0.0.0.0
PORT=8001

# =========================
# OPENAI (LLM)
# =========================
# IMPORTANT: Do NOT put real API key here
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =========================
# STT
# =========================
STT_PROVIDER=local
STT_MODEL=base
STT_LANGUAGE=vi
STT_DEVICE=cpu

# =========================
# DIARIZATION
# =========================
HF_TOKEN=
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# =========================
# STORAGE
# =========================
STORAGE_BASE_DIR=data
RAW_AUDIO_DIR=data/raw
PROCESSED_AUDIO_DIR=data/processed
OUTPUTS_DIR=data/outputs

# =========================
# WORKER
# =========================
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_SECONDS=600
